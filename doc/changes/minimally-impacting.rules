RENAME HEADER cmd.h TO bu/cmd.h SINCE 7.24 # library-specific public headers moved into a subdir [7.24]
RENAME HEADER hist.h TO bu/hist.h SINCE 7.24 # library-specific public headers moved into a subdir [7.24]
RENAME HEADER magic.h TO bu/magic.h SINCE 7.24 # library-specific public headers moved into a subdir [7.24]
RENAME FORM "([^_])([nh]to[hn][fd])" TO "\\1bu_cv_\\2" SINCE 7.24 # ntohf, ntohd, htonf, htond renamed with bu_cv_ prefix [7.24]

# 7.26
RENAME FORM "bu_kill_parallel\\([[:space:]]*\\);" TO "" SINCE 7.26 # didn't do anything unless called from forked process, use bu_terminate() [7.25]
RENAME FORM "bu_jmpbuf" TO "bu_jmpbuf[0]" SINCE 7.26 # can replace 0 with bu_parallel_id() to get thread-safe jumping [7.25]
RENAME FORM "bu_setjmp_valid" TO "bu_setjmp_valid[0]" SINCE 7.26 # can replace 0 with bu_parallel_id() to get thread-safe jumping [7.25]
RENAME TOKEN bu_semaphore_reinit TO bu_semaphore_init SINCE 7.26 # no longer need to manually reinitialize (or initialize) semaphores [7.25]
RENAME HEADER fbio.h TO bu/fb.h SINCE 7.26 # fbio.h is now part of fb.h [7.25]
RENAME FORM "UNION" TO "'u'" SINCE 7.26 # old db.h db4 preprocessor symbols removed, use char or DB_OP_* [7.25]
RENAME FORM "SUBTRACT" TO "'-'" SINCE 7.26 # old db.h db4 preprocessor symbols removed, use char or DB_OP_* [7.25]
RENAME FORM "INTERSECT" TO "'+'" SINCE 7.26 # old db.h db4 preprocessor symbols removed, use char or DB_OP_* [7.25]
