RENAME MACRO SPM_MAGIC TO BN_SPM_MAGIC SINCE 7.20 # SPM_MAGIC renamed to BN_SPM_MAGIC [7.20]
RENAME MACRO SPM_NULL TO BN_SPM_MAP_NULL SINCE 7.20 # SPM_NULL renamed to BN_SPM_MAP_NULL [7.20]
RENAME FORM "BU_EXTERN ( ([^,]*?) , ( ([^)]*) ) )" TO "extern \\1(\\2)" SINCE 7.20 # BU_EXTERN() no longer necessary due to C89 minimum, use extern [7.20]
RENAME FORM "BU_ARGS ( ([^)]* ) )" TO "\\1" SINCE 7.20 # BU_ARGS() no longer necessary due to C89 minimum, list args [7.20]
RENAME FORM "BU_LIST_UNINITIALIZED" TO "!BU_LIST_IS_INITIALIZED" SINCE 7.20 # BU_LIST_IS_INITIALIZED() removed for consistency [7.20]
