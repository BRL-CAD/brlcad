RENAME MACRO RT_CK_DBTR TO RT_CK_DB_TRAVERSE SINCE 7.20 # renamed for API consistency [7.20]
RENAME MACRO RT_DBTR_MAGIC TO RT_DB_TRAVERSE_MAGIC SINCE 7.20 # renamed for API consistency [7.20]
RENAME FORM "RT_INIT_([A-Z_]*)" TO "RT_\\1_INIT" SINCE 7.20 # renamed all RT_INIT_[type] macros to RT_[type]_INIT for API consistency [7.20]
RENAME MACRO BU_LIST_MAGIC_OK TO BU_LIST_MAGIC_EQUAL SINCE 7.20 # renamed and consolidated to be consistent with libbn [7.20]
RENAME FORM "BU_LIST_MAGIC_WRONG" TO "!BU_LIST_MAGIC_EQUAL" SINCE 7.20 # renamed and consolidated to be consistent with libbn [7.20]
RENAME TOKEN nmg_moveeu TO nmg_je SINCE 7.20 # function has been renamed

# 7.22
RENAME TOKEN rt_dist_pt3_line3 TO bn_dist_pt3_line3 SINCE 7.22 # functions moved from librt to libbn [7.21]
RENAME TOKEN rt_dist_line3_line3 TO bn_dist_line3_line3 SINCE 7.22 # functions moved from librt to libbn [7.21]
RENAME TOKEN rt_dist_line3_lseg3 TO bn_dist_line3_lseg3 SINCE 7.22 # functions moved from librt to libbn [7.21]
RENAME TOKEN bu_tcl_setup TO Bu_Init SINCE 7.22 # removed bu_tcl_setup() in favor of Bu_Init() [7.21]
RENAME FORM "bu_tcl_NAME\\(interp, argc, args\\)" TO "bu_NAME(args)" SINCE 7.22 # removed all bu_tcl_*() functions, leaving off interp and using native bu function [7.21]
RENAME FORM "bu_badmagic_tcl\\([^,]*?[[:space:]]*,(.*)" TO "bu_badmagic(\\1" SINCE 7.22 # removed bu_badmagic_tcl() in favor of bu_badmagic() [7.21]
RENAME FORM "(.*)_CK(.*)_TCL\\([^,]*?[[:space:]]*,(.*)" TO "\\1_CK\\2(\\3" SINCE 7.22 # removed all *_CK*_TCL() macros (e.g., BU_CKMAG_TCL, RT_CK_DBI_TCL, etc.) in favor of non-TCL macros [7.21]
RENAME TOKEN bu_image TO icv_image SINCE 7.22 # moved bu_image* functions to libicv as icv_image* [7.21]
RENAME MACRO BU_IMAGE TO ICV_IMAGE SINCE 7.22 # moved BU_IMAGE* macros to icv.h as ICV_IMAGE* [7.21]
RENAME FORM "bu_cmd\\(([^,]*?),[[:space:]]*([^,]*?),[[:space:]]*([^,]*?),[[:space:]]*([^,)]*?),[[:space:]]*([^)]*?)\\)" TO "bu_cmd(\\4, \\2, \\3, \\5, \\1, NULL)" SINCE 7.22 # inputs then outputs. swapped bu_cmd's 4th parameter to 1st, 1st to 5th, and added a new return value hook last. [7.21]
RENAME FORM "V3(.*)_TOL\\(([^,]*,)([^,]*,)([^,]*,)([^)]*)\\)" TO "V3\\1_TOL(\\1\\2\\3(\\4)->dist)" SINCE 7.22 # V3RPP_OVERLAP_TOL(), V3PT_IN_RPP_TOL(), and V3PT_OUT_RPP_TOL() tol parameter changed to value [7.21]
RENAME FORM "BU_GETSTRUCT\\([[:space:]]*([^,)]+,)[[:space:]]*([^)]+)[[:space:]]*\\)" TO "BU_GET(\\1 struct \\2)" SINCE 7.22 # BU_GETSTRUCT(ptr, struct_type) changed to BU_GET(ptr, struct struct_t) [7.21]
RENAME FORM "BU_GETUNION\\([[:space:]]*([^,)]+,)[[:space:]]*([^)]+)[[:space:]]*\\)" TO "BU_GET(\\1 union \\2)" SINCE 7.22 # BU_GETUNION() and BU_GETTYPE() macros changed to BU_GET() [7.21]
RENAME FORM "BU_GETTYPE\\([[:space:]]*([^,)]+,)[[:space:]]*([^)]+)[[:space:]]*\\)" TO "BU_GET(\\1 \\2)" SINCE 7.22 # BU_GETUNION() and BU_GETTYPE() macros changed to BU_GET() [7.21]
RENAME MACRO CMD_NULL TO BU_CMD_NULL SINCE 7.22 # prefix the cmd.h defines with BU_ since they are part of libbu [7.21]
RENAME MACRO CMDHIST TO BU_CMDHIST SINCE 7.22 # prefix the cmd.h defines with BU_ since they are part of libbu [7.21]
RENAME TOKEN bu_shader_to_tcl_list TO bu_shader_to_list SINCE 7.22 # renamed as it applies to any list in {} form, tcl or otherwise [7.21]
RENAME FORM "bu_(add|delete|call)_hook" TO "bu_hook_\\1" SINCE 7.22 # renamed hook functions to be consistent with other libbu API [7.21]
RENAME FORM "bu_file_exists\\(([^)]*)\\)" TO "bu_file_exists(\\1, NULL)" SINCE 7.22 # new file descriptor parameter added [7.21]
RENAME FORM "bu_list_path\\(([^,]*),([^,]*),[[:space:]]*([^)]*)\\)" TO "bu_dir_list(\\1,\\2, &(\\3))" SINCE 7.22 # made bu_dir_list() return the number of entries [7.21]
RENAME FORM "bu_count_path(.*)\\);" TO "bu_dir_list\\1, NULL);" SINCE 7.22 # made bu_dir_list() return the number of entries [7.21]
RENAME FORM "bu_strcmpm\\((.*),([^,]*)\\)" TO "bu_strcmp(\\1)" SINCE 7.22 # no use for label parameter, convert to bu_strcmp() [7.21] bu_set_realtime() [deprecated 7.22]

# 7.24
