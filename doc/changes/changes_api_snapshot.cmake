if(NOT DEFINED CHANGES_SOURCE_DIR)
  message(FATAL_ERROR "CHANGES_SOURCE_DIR is not defined")
endif()
if(NOT DEFINED CHANGES_API_BASELINE)
  message(FATAL_ERROR "CHANGES_API_BASELINE is not defined")
endif()

file(GLOB_RECURSE _headers RELATIVE "${CHANGES_SOURCE_DIR}" "${CHANGES_SOURCE_DIR}/include/*.h")
list(SORT _headers)

set(_api "= BRL-CAD Public API Baseline\n\n")
string(APPEND _api "This file is generated by `changes-api-snapshot`. It records public declarations detected in installed headers for policy-change checking.\n\n")
string(APPEND _api "[source,text]\n----\n")

foreach(_hdr IN LISTS _headers)
  file(STRINGS "${CHANGES_SOURCE_DIR}/${_hdr}" _lines REGEX "^[ \t]*(DEPRECATED[ \t]+)?[A-Z][A-Z0-9_]*_EXPORT|^[ \t]*#[ \t]*define[ \t]+[A-Za-z_][A-Za-z0-9_]*")
  foreach(_line IN LISTS _lines)
    string(STRIP "${_line}" _trimmed)
    if(_trimmed MATCHES "^#[ \t]*define[ \t]+[A-Za-z_][A-Za-z0-9_]*_H($|[ \t])")
      continue()
    endif()
    string(APPEND _api "${_hdr}: ${_trimmed}\n")
  endforeach()
endforeach()

string(APPEND _api "----\n")
file(WRITE "${CHANGES_API_BASELINE}" "${_api}")
message(STATUS "Wrote ${CHANGES_API_BASELINE}")
