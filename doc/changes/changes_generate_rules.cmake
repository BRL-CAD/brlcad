if(NOT DEFINED CHANGES_RULES_FILE)
  message(FATAL_ERROR "CHANGES_RULES_FILE is not defined")
endif()
if(NOT DEFINED CHANGES_GENERATED_ADOC)
  message(FATAL_ERROR "CHANGES_GENERATED_ADOC is not defined")
endif()
if(NOT DEFINED CHANGES_GENERATED_SCRIPT)
  message(FATAL_ERROR "CHANGES_GENERATED_SCRIPT is not defined")
endif()
if(NOT DEFINED CHANGES_APPLY_TEMPLATE)
  message(FATAL_ERROR "CHANGES_APPLY_TEMPLATE is not defined")
endif()

file(READ "${CHANGES_RULES_FILE}" _rules_text)

set(_current_release "")
set(_adoc "= Minimally Impacting Changes\n:toc: macro\n\ntoc::[]\n\n")
string(APPEND _adoc "This file is generated from `minimally-impacting.rules` during the build. Do not edit this file directly.\n\n")

set(_rule_count 0)
while(NOT _rules_text STREQUAL "")
  string(FIND "${_rules_text}" "\n" _newline_pos)
  if(_newline_pos EQUAL -1)
    set(_raw_line "${_rules_text}")
    set(_rules_text "")
  else()
    string(SUBSTRING "${_rules_text}" 0 ${_newline_pos} _raw_line)
    math(EXPR _next_pos "${_newline_pos} + 1")
    string(SUBSTRING "${_rules_text}" ${_next_pos} -1 _rules_text)
  endif()

  string(STRIP "${_raw_line}" _line)
  if(_line STREQUAL "" OR _line MATCHES "^#")
    continue()
  endif()

  string(REGEX REPLACE " SINCE ([^ ]+)[ ]+#.*$" " SINCE \\1" _rule "${_line}")

  if(NOT _rule MATCHES " SINCE [^ ]+$")
    message(FATAL_ERROR "Malformed change rule, missing SINCE: ${_line}")
  endif()

  string(REGEX REPLACE "^.* SINCE ([^ ]+)$" "\\1" _release "${_rule}")

  if(NOT _rule MATCHES "^(RENAME|MOVE|DROP|ADD) ")
    message(FATAL_ERROR "Malformed change rule, unknown verb: ${_line}")
  endif()

  if(NOT _rule MATCHES "^RENAME (FUNCTION|MACRO|TYPE|HEADER|COMMAND|TOKEN|PREFIX|TEXT|FORM) .+ TO .+ SINCE [^ ]+$"
      AND NOT _rule MATCHES "^MOVE FUNCTION [A-Za-z_][A-Za-z0-9_]* PARAMS [^ ]+ TO [^ ]+ SINCE [^ ]+$"
      AND NOT _rule MATCHES "^DROP FUNCTION [A-Za-z_][A-Za-z0-9_]* PARAMS [^ ]+ SINCE [^ ]+$"
      AND NOT _rule MATCHES "^DROP CALL [A-Za-z_][A-Za-z0-9_]* SINCE [^ ]+$"
      AND NOT _rule MATCHES "^ADD FUNCTION [A-Za-z_][A-Za-z0-9_]* PARAMS .+ SINCE [^ ]+$")
    message(FATAL_ERROR "Malformed or unsupported change rule: ${_line}")
  endif()

  if(NOT _release STREQUAL _current_release)
    set(_current_release "${_release}")
    string(APPEND _adoc "\n== ${_release}\n\n")
  endif()

  math(EXPR _rule_count "${_rule_count} + 1")
  string(APPEND _adoc "* `${_rule}`\n")
endwhile()

get_filename_component(_generated_adoc_dir "${CHANGES_GENERATED_ADOC}" DIRECTORY)
file(MAKE_DIRECTORY "${_generated_adoc_dir}")
file(WRITE "${CHANGES_GENERATED_ADOC}" "${_adoc}")

file(READ "${CHANGES_APPLY_TEMPLATE}" _script)
string(REPLACE "@CHANGES_RULES_FILE@" "${CHANGES_RULES_FILE}" _script "${_script}")
string(REPLACE "@CHANGES_RULE_COUNT@" "${_rule_count}" _script "${_script}")
file(WRITE "${CHANGES_GENERATED_SCRIPT}" "${_script}")
file(CHMOD "${CHANGES_GENERATED_SCRIPT}" PERMISSIONS OWNER_READ OWNER_WRITE OWNER_EXECUTE GROUP_READ GROUP_EXECUTE WORLD_READ WORLD_EXECUTE)

message(STATUS "Generated ${_rule_count} change rules")
