# Values set at CMake configure time
set(CBDIR "@CMAKE_CURRENT_BINARY_DIR@")
set(CSDIR "@CMAKE_CURRENT_SOURCE_DIR@")
set(LOGFILE "${CBDIR}/regress-ged_facetize.log")

set(BU_DIR_CACHE ${CBDIR}/cache_facetize)
set(LIBRT_CACHE ${CBDIR}/rtcache_facetize)
set(ENV{BU_DIR_CACHE} ${BU_DIR_CACHE})
set(ENV{LIBRT_CACHE} ${LIBRT_CACHE})
file(REMOVE_RECURSE "${BU_DIR_CACHE}")
file(REMOVE_RECURSE "${LIBRT_CACHE}")
file(MAKE_DIRECTORY "${BU_DIR_CACHE}")
file(MAKE_DIRECTORY "${LIBRT_CACHE}")

set(TMPDIR "${CBDIR}/facetize_regress_tmp")
file(REMOVE_RECURSE "${TMPDIR}")
file(MAKE_DIRECTORY "${TMPDIR}")

file(WRITE "${LOGFILE}" "Starting facetize coplanar regression test run\n")

# The executable locations aren't know at CMake configure time, so it is passed
# in via the EXEC variable at runtime by a generator expression in the parent
# build.  De-quote it and assign it to the appropriate variable.
string(REPLACE "\\" "" FACETIZE_EXEC "${EXEC}")
if(NOT EXISTS "${FACETIZE_EXEC}")
  file(WRITE "${LOGFILE}" "facetize regression program not found at location \"${FACETIZE_EXEC}\" - aborting\n")
  file(READ "${LOGFILE}" LOG)
  message(FATAL_ERROR "Unable to find facetize regression program, aborting.\nSee ${LOGFILE} for more details.\n${LOG}")
endif(NOT EXISTS "${FACETIZE_EXEC}")

# Run the coplanar regression test cases
file(APPEND "${LOGFILE}" "Running ${FACETIZE_EXEC} ${TMPDIR}\n")
execute_process(
  COMMAND "${FACETIZE_EXEC}" "${TMPDIR}"
  RESULT_VARIABLE facetize_result
  OUTPUT_VARIABLE facetize_log
  ERROR_VARIABLE facetize_log
  WORKING_DIRECTORY "${CBDIR}"
)
file(APPEND "${LOGFILE}" "${facetize_log}")
if(facetize_result)
  file(READ "${LOGFILE}" LOG)
  message(FATAL_ERROR "[regress-ged_facetize] Failure: ${facetize_result}. See ${LOGFILE} for more info.\n${LOG}")
endif(facetize_result)

# Clean up
file(REMOVE_RECURSE "${TMPDIR}")
execute_process(
  COMMAND "@CMAKE_COMMAND@" -E rm -rf "${BU_DIR_CACHE}"
)
execute_process(
  COMMAND "@CMAKE_COMMAND@" -E rm -rf "${LIBRT_CACHE}"
)

