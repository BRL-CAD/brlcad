###
# @file BRLCADConfig.cmake.in
#
# CMake package configuration file template for BRL-CAD.
#
# After configure_package_config_file() processes this template the
# resulting BRLCADConfig.cmake is installed to
#   <prefix>/lib/cmake/BRLCAD/BRLCADConfig.cmake
# and is found automatically by find_package(BRLCAD ...) when the
# consumer sets CMAKE_PREFIX_PATH (or the install prefix is in the
# default search list).
#
# Consumer usage:
#
#   find_package(BRLCAD 7.40 REQUIRED COMPONENTS rt wdb ged)
#   target_link_libraries(myapp PRIVATE BRLCAD::rt BRLCAD::wdb BRLCAD::ged)
#
# Available components (all lowercase, matching the short library name):
#   bu bn bg bv nmg brep rt wdb ged analyze gcv icv dm fft optical
#   pkg render tclcad qtcad
#
# Special-purpose components:
#   static  - request static imported targets (BRLCAD::<name>-static)
#
# Compatibility variables (mirrors legacy FindBRLCAD.cmake surface):
#   BRLCAD_FOUND            - TRUE when the package is found
#   BRLCAD_VERSION          - version string "MAJOR.MINOR.PATCH"
#   BRLCAD_INCLUDE_DIRS     - include directories for header-only usage
#   BRLCAD_LIBRARIES        - aggregate imported target (BRLCAD::brlcad)
#   BRLCAD_<UPPER>_LIBRARY  - per-lib imported target, e.g. BRLCAD_RT_LIBRARY
#
###

# ------------------------------------------------------------------
# 1.  Boilerplate generated by configure_package_config_file()
#     sets @PACKAGE_INIT@ and defines set_and_check() / check_required_components()
@PACKAGE_INIT@

# ------------------------------------------------------------------
# 2.  Version and directory variables

set(BRLCAD_VERSION         "@BRLCAD_VERSION@")
set(BRLCAD_VERSION_MAJOR   @BRLCAD_VERSION_MAJOR@)
set(BRLCAD_VERSION_MINOR   @BRLCAD_VERSION_MINOR@)
set(BRLCAD_VERSION_PATCH   @BRLCAD_VERSION_PATCH@)

# Canonical install-tree paths (validated at load time)
set_and_check(BRLCAD_INCLUDE_DIR  "@PACKAGE_BRLCAD_INCLUDE_INSTALL_DIR@")
set_and_check(BRLCAD_LIB_DIR      "@PACKAGE_BRLCAD_LIB_INSTALL_DIR@")
set(BRLCAD_DATA_DIR   "@PACKAGE_BRLCAD_DATA_INSTALL_DIR@")
set(BRLCAD_PLUGIN_DIR "@PACKAGE_BRLCAD_LIB_INSTALL_DIR@/brlcad/plugins")

# BRL-CAD headers live under <prefix>/include/brlcad/ (e.g. rt/geom.h is at
# include/brlcad/rt/geom.h).  Legacy FindBRLCAD.cmake exposed both the parent
# directory (so <prefix>/include/brlcad.h works) and the brlcad/ subdirectory
# (so rt/geom.h works).  Replicate that here so consumers that do
#   INCLUDE_DIRECTORIES(${BRLCAD_INCLUDE_DIRS})
# get the same behaviour they had before.
if(IS_DIRECTORY "${BRLCAD_INCLUDE_DIR}/brlcad")
  set(BRLCAD_HEADERS_DIR "${BRLCAD_INCLUDE_DIR}/brlcad")
else()
  set(BRLCAD_HEADERS_DIR "${BRLCAD_INCLUDE_DIR}")
endif()

# ------------------------------------------------------------------
# 3.  Search-path setup for bundled dependencies
#
# Prepend the modules/ sub-directory shipped alongside this file so
# that find_dependency() calls below can locate BRL-CAD's private
# find-modules for packages that were bundled at build time.
list(INSERT CMAKE_MODULE_PATH 0 "${CMAKE_CURRENT_LIST_DIR}/modules")

# Also prepend the BRL-CAD installation prefix to CMAKE_PREFIX_PATH so
# that find_dependency() can locate packaged bundled deps (mmesh, manifold,
# etc.) installed to <prefix>/lib/cmake/<Dep>/<Dep>Config.cmake.
# BRLCAD_LIB_DIR is already set and validated above; its parent is the prefix.
get_filename_component(_brlcad_prefix "${BRLCAD_LIB_DIR}/.." ABSOLUTE)
list(INSERT CMAKE_PREFIX_PATH 0 "${_brlcad_prefix}")

# ------------------------------------------------------------------
# 4.  Re-find external dependencies required by BRL-CAD's targets
#
# Any library whose targets are referenced in INTERFACE_LINK_LIBRARIES
# of an exported BRL-CAD target must exist before BRLCADTargets.cmake
# is included.  We use find_dependency() here so that errors are
# attributed to the consumer's find_package(BRLCAD) call.

include(CMakeFindDependencyMacro)

find_dependency(Threads)

# Bundled-or-system deps that are always used
@BRLCAD_FIND_DEP_ZLIB@
@BRLCAD_FIND_DEP_LMDB@
@BRLCAD_FIND_DEP_REGEX@
@BRLCAD_FIND_DEP_PNG@
@BRLCAD_FIND_DEP_NETPBM@
@BRLCAD_FIND_DEP_JPEG@
@BRLCAD_FIND_DEP_OPENNURBS@
@BRLCAD_FIND_DEP_GEOGRAM@

# BRL-CAD bundled mesh/geometry libraries whose targets appear in
# the exported link interface of librt.
find_dependency(mmesh)
find_dependency(manifold)

# Optional deps gated by the build-time feature flags
if(@BRLCAD_HAVE_TCL@)
  find_dependency(TCL)
endif()
if(@BRLCAD_HAVE_QT@)
  find_dependency(Qt6 COMPONENTS Core Gui Widgets OpenGLWidgets QUIET)
  if(NOT Qt6_FOUND)
    find_dependency(Qt5 COMPONENTS Core Gui Widgets)
  endif()
endif()
if(@BRLCAD_HAVE_OPENGL@)
  find_dependency(OpenGL)
endif()
if(@BRLCAD_HAVE_GDAL@)
  find_dependency(GDAL QUIET)
endif()
if(@BRLCAD_HAVE_OPENCL@)
  find_dependency(OpenCL QUIET)
endif()

# ------------------------------------------------------------------
# 5.  Decide shared vs static
#
# By default the shared imported targets are used.  Consumers may
# additionally request static targets by either:
#   - Setting BRLCAD_USE_STATIC_LIBS=ON before find_package()
#   - Including "static" in the COMPONENTS list
#
# Both BRLCADTargets.cmake (shared) and BRLCADStaticTargets.cmake
# (static, when installed) are included when static is requested so
# that the full target namespace is available.  The aggregate
# BRLCAD::brlcad target and the per-library compat variables then
# resolve to the preferred variant automatically.

set(_brlcad_want_static ${BRLCAD_USE_STATIC_LIBS})
if(BRLCAD_FIND_COMPONENTS)
  list(FIND BRLCAD_FIND_COMPONENTS "static" _brlcad_static_idx)
  if(NOT _brlcad_static_idx EQUAL -1)
    set(_brlcad_want_static TRUE)
  endif()
endif()

# ------------------------------------------------------------------
# 6.  Include the generated targets file(s)
#
# The shared-targets file is always loaded when present; the static-
# targets file is loaded on top of it when the consumer opts in.
# This ensures that both BRLCAD::rt (shared) and BRLCAD::rt-static
# are visible in the same CMake session when static mode is active.

if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/BRLCADTargets.cmake")
  include("${CMAKE_CURRENT_LIST_DIR}/BRLCADTargets.cmake")
elseif(NOT EXISTS "${CMAKE_CURRENT_LIST_DIR}/BRLCADStaticTargets.cmake")
  set(BRLCAD_NOT_FOUND_MESSAGE
    "BRL-CAD package configuration file was found but no target files exist. "
    "The installation may be incomplete.")
  set(BRLCAD_FOUND FALSE)
  return()
endif()

if(_brlcad_want_static)
  if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/BRLCADStaticTargets.cmake")
    include("${CMAKE_CURRENT_LIST_DIR}/BRLCADStaticTargets.cmake")
  else()
    message(WARNING
      "BRLCAD_USE_STATIC_LIBS was requested but BRL-CAD was not built with "
      "BUILD_STATIC_LIBS=ON (BRLCADStaticTargets.cmake is absent). "
      "Falling back to shared targets.")
    set(_brlcad_want_static FALSE)
  endif()
endif()

# ------------------------------------------------------------------
# 7.  Aggregate convenience target BRLCAD::brlcad
#
# Links every public library that was actually built.  When static
# targets are available and requested, the aggregate uses the static
# variants so that a single BRLCAD::brlcad reference is sufficient.
# Legacy consumers that just write:
#   target_link_libraries(myapp PRIVATE BRLCAD::brlcad)
# automatically get the right variant.

if(NOT TARGET BRLCAD::brlcad)
  set(_brlcad_all_libs)
  foreach(_lib
      bu bn bg bv nmg brep rt wdb ged analyze gcv icv dm fft optical pkg render
      tclcad qtcad)
    if(_brlcad_want_static AND TARGET BRLCAD::${_lib}-static)
      list(APPEND _brlcad_all_libs BRLCAD::${_lib}-static)
    elseif(TARGET BRLCAD::${_lib})
      list(APPEND _brlcad_all_libs BRLCAD::${_lib})
    endif()
  endforeach()
  add_library(BRLCAD::brlcad INTERFACE IMPORTED)
  set_target_properties(BRLCAD::brlcad PROPERTIES
    INTERFACE_LINK_LIBRARIES "${_brlcad_all_libs}"
  )
endif()

# ------------------------------------------------------------------
# 8.  Component validation
#
# Known optional components and which build-time flag controls them.
set(_brlcad_optional_components tclcad qtcad step gdal dm-osmesa opencl)
set(_brlcad_have_tclcad   @BRLCAD_HAVE_TCL@)
set(_brlcad_have_qtcad    @BRLCAD_HAVE_QT@)
set(_brlcad_have_step     @BRLCAD_HAVE_STEP@)
set(_brlcad_have_gdal     @BRLCAD_HAVE_GDAL@)
set(_brlcad_have_dm-osmesa @BRLCAD_HAVE_OSMESA@)
set(_brlcad_have_opencl   @BRLCAD_HAVE_OPENCL@)

# All mandatory (non-optional) public library components
set(_brlcad_mandatory_components
  bu bn bg bv nmg brep rt wdb ged analyze gcv icv dm fft optical pkg render)

foreach(_comp ${BRLCAD_FIND_COMPONENTS})
  if("${_comp}" STREQUAL "static")
    # Handled above
    set(BRLCAD_static_FOUND TRUE)
    continue()
  endif()

  # Check mandatory libs first
  list(FIND _brlcad_mandatory_components "${_comp}" _brlcad_comp_idx)
  if(NOT _brlcad_comp_idx EQUAL -1)
    if(TARGET BRLCAD::${_comp})
      set(BRLCAD_${_comp}_FOUND TRUE)
    else()
      set(BRLCAD_${_comp}_FOUND FALSE)
    endif()
    continue()
  endif()

  # Optional components
  list(FIND _brlcad_optional_components "${_comp}" _brlcad_opt_idx)
  if(NOT _brlcad_opt_idx EQUAL -1)
    if(_brlcad_have_${_comp})
      if(TARGET BRLCAD::${_comp})
        set(BRLCAD_${_comp}_FOUND TRUE)
      else()
        set(BRLCAD_${_comp}_FOUND FALSE)
      endif()
    else()
      set(BRLCAD_${_comp}_FOUND FALSE)
    endif()
    continue()
  endif()

  # Unknown component: mark found if a matching target exists
  if(TARGET BRLCAD::${_comp})
    set(BRLCAD_${_comp}_FOUND TRUE)
  else()
    set(BRLCAD_${_comp}_FOUND FALSE)
  endif()
endforeach()

# ------------------------------------------------------------------
# 9.  Backward-compatible variable surface (mirrors FindBRLCAD.cmake)

set(BRLCAD_FOUND TRUE)
# Expose both the parent include dir and the brlcad/ subdirectory so that
# consumers who do INCLUDE_DIRECTORIES(${BRLCAD_INCLUDE_DIRS}) can use
# both #include "brlcad/bu.h" and #include "bu.h" / #include "rt/geom.h".
set(BRLCAD_INCLUDE_DIRS "${BRLCAD_INCLUDE_DIR}" "${BRLCAD_HEADERS_DIR}")
list(REMOVE_DUPLICATES BRLCAD_INCLUDE_DIRS)
set(BRLCAD_LIBRARIES BRLCAD::brlcad)

foreach(_lib
    bu bn bg bv nmg brep rt wdb ged analyze gcv icv dm fft optical pkg render
    tclcad qtcad)
  string(TOUPPER "${_lib}" _LIB)
  if(TARGET BRLCAD::${_lib})
    set(BRLCAD_${_LIB}_LIBRARY BRLCAD::${_lib})
  endif()
  if(TARGET BRLCAD::${_lib}-static)
    set(BRLCAD_${_LIB}_STATIC_LIBRARY BRLCAD::${_lib}-static)
  endif()
endforeach()

# ------------------------------------------------------------------
# 10. Final required-components check

check_required_components(BRLCAD)

# Restore search paths so our private entries don't leak into the
# consumer's scope.
list(REMOVE_AT CMAKE_MODULE_PATH 0)
list(REMOVE_AT CMAKE_PREFIX_PATH 0)

# Local Variables:
# tab-width: 8
# mode: cmake
# indent-tabs-mode: t
# End:
