#20=DIMENSIONAL_EXPONENTS(1.,0.,0.,0.,0.,0.,0.);
#21=(LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.));
#22=(NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.));
#23=(NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT());
#24=UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-6),#21,'distance_accuracy_value','maximum gap value');
#25=(GEOMETRIC_REPRESENTATION_CONTEXT(3) GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#24)) GLOBAL_UNIT_ASSIGNED_CONTEXT((#21,#22,#23)) REPRESENTATION_CONTEXT('fixture','3D'));
#26=SHAPE_REPRESENTATION('',(#6),#25);
#30=APPLICATION_CONTEXT('automotive design');
#31=APPLICATION_PROTOCOL_DEFINITION('fixture','automotive_design',2010,#30);
#32=PRODUCT_CONTEXT('',#30,'mechanical');
#33=PRODUCT_DEFINITION_CONTEXT('part definition',#30,'design');
#34=PRODUCT('hollow_sweep','Hollow Sweep','exact linear swept-disk fixture',(#32));
#35=PRODUCT_DEFINITION_FORMATION_WITH_SPECIFIED_SOURCE('1','initial revision',#34,.MADE.);
#36=PRODUCT_DEFINITION('design','fixture swept-disk definition',#35,#33);
#37=PRODUCT_DEFINITION_SHAPE('','',#36);
