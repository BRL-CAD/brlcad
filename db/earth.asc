title {Earth Model v1.1 by starseeker}
units km
put {mesosphere.s} ell V {0 0 0}  A {6468100000 0 0}  B {0 6468100000 0}  C {0 0 6446800000} 
put {mesosphere.c} comb region no tree {- {l mesosphere.s} {l stratosphere.s}}
attr set {mesosphere.c} {shader} {glass {tr 0.85}}
put {atmosphere.c} comb region no tree {u {u {- {l mesosphere.c} {l slice-earth-2.s}} {- {l stratosphere.c} {l slice-earth-2.s}}} {- {l troposphere.c} {l slice-earth-2.s}}}
put {outer-core.s} ell V {0 0 0}  A {-2394906651.625486850738525 1382699999.999999523162842 0}  B {-1382699999.999999523162842 -2394906651.625486850738525 0}  C {0 0 2750000000} 
put {inner-core.s} ell V {0 0 0}  A {-1047890738.579170942306519 604999999.9999997615814209 0}  B {-604999999.9999997615814209 -1047890738.579170942306519 0}  C {0 0 1210000000} 
put {inner-core.r} comb region yes tree {n {l inner-core.s} {l slice-earth-2.s}}
attr set {inner-core.r} {color} {255/255/255} {shader} {plastic {sp 0.9 di 0.1}} {region} {R} {region_id} {1003} {material_id} {1} {los} {100}
put {lower-mantle-core-subtract.c} comb region no tree {u {l outer-core.s} {l inner-core.s}}
put {upper-mantle-core-subtract.c} comb region no tree {u {u {l lower-mantle.s} {l outer-core.s}} {l inner-core.s}}
put {slice-earth-outcore.s} arb8 V1 {1000000 1000000 1000000}  V2 {1500000000 11550000000 1500000000}  V3 {11550000000 1500000000 1500000000}  V4 {1000000 1000000 1000000}  V5 {1500000000 1500000000 11550000000}  V6 {1500000000 1500000000 11550000000}  V7 {1500000000 1500000000 11550000000}  V8 {1500000000 1500000000 11550000000} 
put {crust-core-subtract.c} comb region no tree {u {u {l upper-mantle.s} {l lower-mantle.s}} {u {l outer-core.s} {l inner-core.s}}}
put {outer-core-display.r} comb region yes tree {- {n {l outer-core.s} {l slice-earth-2.s}} {l inner-core.s}}
attr set {outer-core-display.r} {color} {254/255/178} {shader} {plastic} {region} {R} {region_id} {1002} {material_id} {1} {los} {100}
put {slice-earth-lowman.s} arb8 V1 {1000000 1000000 1000000}  V2 {1000000000 11550000000 1000000000}  V3 {11550000000 1000000000 1000000000}  V4 {1000000 1000000 1000000}  V5 {1000000000 1000000000 11550000000}  V6 {1000000000 1000000000 11550000000}  V7 {1000000000 1000000000 11550000000}  V8 {1000000000 1000000000 11550000000} 
put {earth-cutaway.c} comb region no tree {- {l earth-crust.c} {l slice-earth.s}}
put {earth-display.c} comb region no tree {u {u {u {u {u {l earth-cutaway.c} {l cutout-earth-backdrop.c}} {- {l upper-mantle-display.r} {l slice-earth-upman.s}}} {- {l lower-mantle-display.r} {l slice-earth-lowman.s}}} {- {l outer-core-display.r} {l slice-earth-outcore.s}}} {l inner-core.r}}
put {stratosphere.s} ell V {0 0 0}  A {6428100000 0 0}  B {0 6428100000 0}  C {0 0 6406800000} 
put {stratosphere.c} comb region no tree {- {l stratosphere.s} {l troposphere.s}}
attr set {stratosphere.c} {shader} {glass {tr 0.8}}
put {cutout-earth-backdrop.c} comb region no tree {n {l cutout-earth.c} {l earth-crust.s}}
put {lower-mantle.s} ell V {0 0 0}  A {-4900404747.314247131347656 2829249999.999999046325684 0}  B {-2829249999.999999046325684 -4900404747.314247131347656 0}  C {0 0 5640000000} 
put {upper-mantle.s} ell V {0 0 0}  A {-5474406384.942572593688965 3160649999.999999046325684 0}  B {-3160649999.999999046325684 -5474406384.942572593688965 0}  C {0 0 6300000000} 
put {slice-earth-2.s} arb8 V1 {1000000 1000000 1000000}  V2 {1000000 11550000000 1000000}  V3 {11550000000 1000000 1000000}  V4 {1000000 1000000 1000000}  V5 {1000000 1000000 11550000000}  V6 {1000000 1000000 11550000000}  V7 {1000000 1000000 11550000000}  V8 {1000000 1000000 11550000000} 
put {slice-earth-upman.s} arb8 V1 {1000000 1000000 1000000}  V2 {500000000 11550000000 500000000}  V3 {11550000000 500000000 500000000}  V4 {1000000 1000000 1000000}  V5 {500000000 500000000 11550000000}  V6 {500000000 500000000 11550000000}  V7 {500000000 500000000 11550000000}  V8 {500000000 500000000 11550000000} 
put {cutout-earth.c} comb region no tree {- {l slice-earth.s} {l slice-earth-2.s}}
put {troposphere.s} ell V {0 0 0}  A {6396100000 0 0}  B {0 6396100000 0}  C {0 0 6374800000} 
put {earth-crust.s} ell V {0 0 0}  A {-5523596627.877529144287109 3189049999.999999046325684 0}  B {-3189049999.999999046325684 -5523596627.877529144287109 0}  C {0 0 6356800000} 
put {troposphere.c} comb region no tree {- {l troposphere.s} {l earth-crust.s}}
attr set {troposphere.c} {shader} {stack {{cloud {}} {glass {tr 0.65}}}}
put {earth-crust.c} comb region no tree {- {l earth-crust.s} {l crust-core-subtract.c}}
attr set {earth-crust.c} {shader} {texture {file earth.pix w 21600 n 10800}}
put {slice-earth.s} arb8 V1 {0 0 0}  V2 {0 11500000000 0}  V3 {11500000000 0 0}  V4 {0 0 0}  V5 {0 0 11500000000}  V6 {0 0 11500000000}  V7 {0 0 11500000000}  V8 {0 0 11500000000} 
put {lower-mantle-display.r} comb region yes tree {- {n {l lower-mantle.s} {l slice-earth-2.s}} {l lower-mantle-core-subtract.c}}
attr set {lower-mantle-display.r} {color} {255/255/0} {shader} {plastic} {region} {R} {region_id} {1001} {material_id} {1} {los} {100}
put {upper-mantle-display.r} comb region yes tree {- {n {l upper-mantle.s} {l slice-earth-2.s}} {l upper-mantle-core-subtract.c}}
attr set {upper-mantle-display.r} {color} {254/160/60} {shader} {plastic} {region} {R} {region_id} {1000} {material_id} {1} {los} {100}
